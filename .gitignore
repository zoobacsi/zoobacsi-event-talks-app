# pyenv
#   For a library or app, you might want to share your .python-version.
#   See https://github.com/pyenv/pyenv/blob/master/COMMANDS.md#pyenv-version-file
#.python-version

# pipenv
#   According to Pipfile.lock spec, it should be committed.
#   But it should be ignored if this is a development system.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is database file, should be committed.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is database file, should be committed.
#.pdm-python.path
#.pdm-build/

# PEP 582; dependency directory created by pipflow via pdm or poetry
__pypackages__/

